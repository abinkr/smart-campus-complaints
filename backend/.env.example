NODE_ENV=development
PORT=5000

DATABASE_URL=postgresql://postgres:replace-with-password@localhost:5432/campus_complaints?schema=public
# If using Supabase Connection Pooler on port 6543 (transaction mode), append "?pgbouncer=true&connection_limit=1"
# DATABASE_URL=postgresql://postgres.YOUR-REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:replace-with-password@localhost:5432/campus_complaints?schema=public
# If using Supabase Connection Pooler, DIRECT_URL should connect directly (port 5432)
# DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR-REF.supabase.co:5432/postgres

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-access-secret-minimum-32-chars
JWT_REFRESH_SECRET=replace-with-refresh-secret-minimum-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=5
MFA_CODE_EXPIRY_MINUTES=5
MFA_MAX_ATTEMPTS=5
MFA_PROVIDER=smtp


NLP_SERVICE_URL=http://localhost:5001
NLP_TIMEOUT_MS=10000

CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=Smart Campus <no-reply@example.com>

CLIENT_URL=https://student.example.com
STUDENT_CLIENT_URL=https://student.example.com
ADMIN_CLIENT_URL=https://admin.example.com
SENTRY_DSN=
RELOAD_SECRET=internal-secret
ADMIN_REGISTRATION_KEY=replace-with-admin-registration-key

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TIMEOUT_MS=10000

# SendGrid Configuration
SENDGRID_API_KEY=replace-with-sendgrid-api-key
