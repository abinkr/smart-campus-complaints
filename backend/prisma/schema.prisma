generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String            @db.VarChar(100)
  email               String            @unique(map: "users_email_unique") @db.VarChar(255)
  password            String            @db.VarChar(255)
  role                Role              @default(STUDENT)
  department          String?           @db.VarChar(100)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  loginFailedAttempts Int               @default(0) @map("login_failed_attempts")
  lockedUntil         DateTime?         @map("locked_until") @db.Timestamptz(6)
  logs                ComplaintLog[]    @relation("AdminLogs")
  complaints          Complaint[]       @relation("UserComplaints")
  mfaChallenges       MfaChallenge[]
  refreshTokens       RefreshToken[]
  publicUpdates       PublicUpdate[]
  internalNotes       InternalNote[]
  studentFollowUps    StudentFollowUp[]

  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
  @@index([lockedUntil], map: "idx_users_locked_until")
  @@map("users")
}

model Complaint {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  title         String            @db.VarChar(200)
  description   String
  imageUrl      String?           @map("image_url") @db.VarChar(500)
  category      String?           @db.VarChar(50)
  priority      Priority?
  nlpConfidence Decimal?          @map("nlp_confidence") @db.Decimal(5, 2)
  status        Status            @default(OPEN)
  department    String?           @db.VarChar(100)
  adminNote     String?           @map("admin_note")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  resolvedAt    DateTime?         @map("resolved_at") @db.Timestamptz(6)
  logs          ComplaintLog[]
  user          User              @relation("UserComplaints", fields: [userId], references: [id], onDelete: Cascade, map: "complaints_user_fk")
  publicUpdates PublicUpdate[]
  internalNotes InternalNote[]
  studentFollowUps StudentFollowUp[]

  @@index([userId], map: "idx_complaints_user_id")
  @@index([status], map: "idx_complaints_status")
  @@index([priority], map: "idx_complaints_priority")
  @@index([category], map: "idx_complaints_category")
  @@index([createdAt(sort: Desc)], map: "idx_complaints_created_at")
  @@index([status, priority], map: "idx_complaints_status_priority")
  @@index([department, status], map: "idx_complaints_department_status")
  @@map("complaints")
}

model ComplaintLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complaintId String    @map("complaint_id") @db.Uuid
  changedBy   String?   @map("changed_by") @db.Uuid
  oldStatus   String?   @map("old_status") @db.VarChar(30)
  newStatus   String?   @map("new_status") @db.VarChar(30)
  note        String?
  changedAt   DateTime  @default(now()) @map("changed_at") @db.Timestamptz(6)
  isInternal  Boolean   @default(false) @map("is_internal")
  admin       User?     @relation("AdminLogs", fields: [changedBy], references: [id], map: "logs_admin_fk")
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade, map: "logs_complaint_fk")

  @@index([complaintId], map: "idx_logs_complaint_id")
  @@index([changedBy], map: "idx_logs_changed_by")
  @@index([changedAt(sort: Desc)], map: "idx_logs_changed_at")
  @@map("complaint_logs")
}

model PublicUpdate {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complaintId      String    @map("complaint_id") @db.Uuid
  message          String
  createdByAdminId String    @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  complaint        Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade, map: "public_updates_complaint_fk")
  admin            User      @relation(fields: [createdByAdminId], references: [id], onDelete: Cascade, map: "public_updates_admin_fk")

  @@index([complaintId], map: "idx_public_updates_complaint_id")
  @@map("public_updates")
}

model InternalNote {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complaintId      String    @map("complaint_id") @db.Uuid
  note             String
  createdByAdminId String    @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  complaint        Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade, map: "internal_notes_complaint_fk")
  admin            User      @relation(fields: [createdByAdminId], references: [id], onDelete: Cascade, map: "internal_notes_admin_fk")

  @@index([complaintId], map: "idx_internal_notes_complaint_id")
  @@map("internal_notes")
}

model StudentFollowUp {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complaintId String    @map("complaint_id") @db.Uuid
  message     String
  studentId   String    @map("student_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade, map: "student_follow_ups_complaint_fk")
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "student_follow_ups_student_fk")

  @@index([complaintId], map: "idx_student_follow_ups_complaint_id")
  @@map("student_follow_ups")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash String   @unique(map: "refresh_tokens_token_hash_unique") @map("token_hash") @db.VarChar(64)
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "refresh_tokens_user_fk")

  @@index([tokenHash], map: "idx_refresh_tokens_token_hash")
  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@index([expiresAt], map: "idx_refresh_tokens_expires_at")
  @@map("refresh_tokens")
}

model MfaChallenge {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  attempts        Int       @default(0)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt      DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  codeHash        String?   @map("code_hash") @db.VarChar(255)
  verificationSid String?   @map("verification_sid") @db.VarChar(64)
  deliveryChannel String    @default("email") @map("delivery_channel") @db.VarChar(20)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "mfa_challenges_user_fk")

  @@index([userId], map: "idx_mfa_challenges_user_id")
  @@index([verificationSid], map: "idx_mfa_challenges_verification_sid")
  @@index([expiresAt], map: "idx_mfa_challenges_expires_at")
  @@index([consumedAt], map: "idx_mfa_challenges_consumed_at")
  @@map("mfa_challenges")
}

model Department {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique(map: "departments_name_unique") @db.VarChar(100)

  @@map("departments")
}

enum Role {
  STUDENT
  ADMIN

  @@map("role_enum")
}

enum Status {
  OPEN
  IN_PROGRESS
  RESOLVED

  @@map("status_enum")
}

enum Priority {
  HIGH
  MEDIUM
  LOW

  @@map("priority_enum")
}
